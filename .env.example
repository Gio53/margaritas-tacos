# =============================================================================
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# Orders API — for cross-device sync (phone order shows on main dashboard).
# Run the server on another port: PORT=3001 npm run dev:server
# Then set this so all devices use the same orders. Leave empty for single-device (localStorage).
VITE_ORDERS_API_URL=http://localhost:3001

# Checkout API — leave empty for demo (no charge). When using Clover, set to your server URL
# (same as VITE_ORDERS_API_URL in production, e.g. https://your-app.onrender.com).
VITE_CHECKOUT_API_URL=

# -----------------------------------------------------------------------------
# Clover API — set on the SERVER (e.g. Render). See docs/CLOVER_INTEGRATION.md.
# -----------------------------------------------------------------------------
CLOVER_SANDBOX=true
CLOVER_ACCESS_TOKEN=your-oauth-access-token
CLOVER_ECOM_API_KEY=your-pakms-ecom-api-key

# Clover REST API v3 — for full orders + receipts on Clover Station (line items, print).
# Get these from Clover Dashboard → API Tokens. Token needs Read Orders + Write Orders.
CLOVER_MERCHANT_ID=
CLOVER_API_TOKEN=

# -----------------------------------------------------------------------------
# Order ready: SMS via Twilio (primary). See docs/SMS_READY_NOTIFICATION.md.
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Optional (later): Email e.g. for order-ready or ads. Resend = 100 emails/day free.
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=orders@yourdomain.com
